# Database (Neon)
# Runtime: pooled connection (hostname contains "-pooler") — used by the Next.js app
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# Migrations: direct/unpooled connection — used by `prisma migrate` (optional but recommended)
DIRECT_DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# LinkedIn OAuth
# Redirect URI is derived automatically: {APP_URL}/api/auth/linkedin/callback
# Add the same URL in LinkedIn Developer → Auth → Authorized redirect URLs
LINKEDIN_CLIENT_ID=...
LINKEDIN_CLIENT_SECRET=...

# Twitter / X OAuth 2.0 (PKCE — configured in Step 14)
# Redirect URI is derived automatically: {APP_URL}/api/auth/twitter/callback
# Add the same URL in X Developer Portal → User authentication settings → Callback URI
# App permissions must be Read and write. Website URL: http://localhost:3000
TWITTER_CLIENT_ID=...
TWITTER_CLIENT_SECRET=...

# Facebook (later milestone)
FACEBOOK_APP_ID=...
FACEBOOK_APP_SECRET=...

# Cloudflare R2
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=...
R2_PUBLIC_URL=https://...
